datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id                String                 @id @default(uuid())
  name              String
  createdAt         DateTime               @default(now())
  users             User[]
  waConfig          WhatsAppConfig?
  igConfig          InstagramConfig?
  gmbConfig         GoogleBusinessConfig?
  flows             Flow[]
  conversations     Conversation[]
  googleReviews     GoogleReview[]
  googlePosts       GooglePost[]
  googleQuestions   GoogleQuestion[]
  googleAdCampaigns GoogleAdCampaign[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String
  name           String
  role           String       @default("agent") // admin, agent
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model WhatsAppConfig {
  id                    String       @id @default(uuid())
  organizationId        String       @unique
  organization          Organization @relation(fields: [organizationId], references: [id])
  phoneNumberId         String?      
  wabaId                String?      
  accessToken           String?      
  webhookVerifyToken    String       @default(uuid())
}

model Flow {
  id             String       @id @default(uuid())
  name           String
  description    String?
  platform       String       @default("whatsapp")
  graphJson      Json         // Native JSON field to store React Flow graph
  isActive       Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Conversation {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  platform       String       @default("whatsapp")
  customerPhone  String       
  customerName   String?
  currentNodeId  String?      // State tracker in visual flow
  isBotPaused    Boolean      @default(false)
  botPausedUntil DateTime?
  messages       Message[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, platform, customerPhone])
}

model InstagramConfig {
  id                    String       @id @default(uuid())
  organizationId        String       @unique
  organization          Organization @relation(fields: [organizationId], references: [id])
  instagramAccountId    String?      
  pageId                String?      
  pageAccessToken       String?      
  webhookVerifyToken    String       @default(uuid())
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  direction      String       // "inbound" or "outbound"
  messageType    String       // "text", "image", "document", "interactive_response"
  content        String       // Text content or Media URL
  mediaMimeType  String?
  waMessageId    String?      // Meta's ID to map status updates
  status         String       @default("sent") // sent, delivered, read, failed
  senderName     String?      // "Bot" or Agent's Name
  createdAt      DateTime     @default(now())

  // Quote reply relations
  quotedMessageId String?
  quotedMessage   Message?    @relation("MessageReplies", fields: [quotedMessageId], references: [id])
  replies         Message[]   @relation("MessageReplies")
}

model GoogleBusinessConfig {
  id                    String       @id @default(uuid())
  organizationId        String       @unique
  organization          Organization @relation(fields: [organizationId], references: [id])
  locationName          String?      
  googlePlaceId         String?      
  googleReviewUrl       String?      
  googleLocationId      String?      
  googleClientId        String?      
  googleClientSecret    String?      
  googleRefreshToken    String?      
  googleAdsCustomerId   String?      
  autoReplyEnabled      Boolean      @default(false)
  autoReplyMinRating    Int          @default(4)
  autoReplyTemplate     String?      
  
  // Local profile fallbacks
  websiteUri            String?
  primaryPhone          String?
  description           String?
  address               String?
  regularHours          String?      // Stored as serialized JSON string

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model GoogleReview {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  customerName   String
  rating         Int
  comment        String?
  status         String       @default("PENDING") // PENDING, APPROVED, DECLINED
  replyText      String?
  replyStatus    String       @default("UNREPLIED") // UNREPLIED, REPLIED
  source         String       @default("FUNNEL") // FUNNEL, GOOGLE
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model GooglePost {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  gmbPostId      String?      @unique
  title          String?
  summary        String
  mediaUrl       String?
  callToActionType String?    // LEARN_MORE, BOOK, ORDER, SIGN_UP, etc.
  callToActionUrl  String?
  status         String       @default("DRAFT") // DRAFT, PUBLISHED, FAILED
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model GoogleQuestion {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  gmbQuestionId  String       @unique
  authorName     String
  text           String
  aiAnswer       String?
  answerText     String?
  status         String       @default("UNANSWERED") // UNANSWERED, ANSWERED, AUTO_ANSWERED
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model GoogleAdCampaign {
  id                  String       @id @default(uuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  googleAdsCampaignId String?      @unique
  name                String
  budget              Float
  startDate           DateTime
  endDate             DateTime?
  status              String       @default("DRAFT") // DRAFT, ENABLED, PAUSED
  headlines           Json         // List of headlines for responsive search ads
  descriptions        Json         // List of descriptions
  keywords            Json         // Target keywords
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}


