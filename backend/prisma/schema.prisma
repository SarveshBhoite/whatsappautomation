datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id                  String                 @id @default(uuid())
  name                String
  createdAt           DateTime               @default(now())
  users               User[]
  waConfig            WhatsAppConfig?
  igConfig            InstagramConfig?
  ytConfig            YouTubeConfig?
  gmbConfig           GoogleBusinessConfig?
  linkedInConfig      LinkedInConfig?
  linkedInPosts       LinkedInPost[]
  gmailConfig         GmailConfig?
  gmailAutoReplyRules GmailAutoReplyRule[]
  flows               Flow[]
  conversations       Conversation[]
  googleReviews       GoogleReview[]
  googlePosts         GooglePost[]
  googleQuestions     GoogleQuestion[]
  googleAdCampaigns   GoogleAdCampaign[]
  googleAdAccounts    GoogleAdAccount[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String?
  role           String       @default("agent") // "admin" or "agent"
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

model WhatsAppConfig {
  id                 String       @id @default(uuid())
  organizationId     String       @unique
  organization       Organization @relation(fields: [organizationId], references: [id])
  phoneNumberId      String?
  wabaId             String?
  accessToken        String?
  webhookVerifyToken String       @default(uuid())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model InstagramConfig {
  id                 String       @id @default(uuid())
  organizationId     String       @unique
  organization       Organization @relation(fields: [organizationId], references: [id])
  pageId             String?
  pageAccessToken    String?
  webhookVerifyToken String       @default(uuid())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model YouTubeConfig {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  channelId      String?
  channelName    String?      // Handle or Display Name (e.g. @MyBrand)
  accessToken    String?
  refreshToken   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Flow {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  platform       String       @default("whatsapp") // "whatsapp", "instagram", "youtube"
  name           String
  graphJson      Json         // ReactFlow nodes and edges
  isActive       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, platform, name])
}

model Conversation {
  id             String    @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  platform       String    // "whatsapp", "instagram", "youtube"
  customerPhone  String    // E.164 phone number, IG scoped ID, or YouTube comment ID
  customerName   String?
  currentNodeId  String?   // Tracks progress in the FlowGraph
  isBotPaused    Boolean   @default(false) // True when agent takes over
  botPausedUntil DateTime? // Expiration timestamp for manual takeover
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  messages       Message[]

  @@unique([organizationId, platform, customerPhone])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  direction      String       // "inbound" or "outbound"
  messageType    String       // "text", "image", "document", "interactive_response"
  content        String       // Text content or Media URL
  mediaMimeType  String?
  waMessageId    String?      // Meta's ID to map status updates
  status         String       @default("sent") // sent, delivered, read, failed
  senderName     String?      // "Bot" or Agent's Name
  createdAt      DateTime     @default(now())

  // Quote reply relations
  quotedMessageId String?
  quotedMessage   Message?    @relation("MessageReplies", fields: [quotedMessageId], references: [id])
  replies         Message[]   @relation("MessageReplies")
}

model GoogleBusinessConfig {
  id                 String       @id @default(uuid())
  organizationId     String       @unique
  organization       Organization @relation(fields: [organizationId], references: [id])
  googleAccountId    String?      // Google Account ID (accounts/12345)
  googleLocationId   String?      // Google Location ID (locations/67890)
  googleLocationName String?      // Friendly Business Name (e.g., "Jisnu Digital Solutions - Head Office")
  googleRefreshToken String?      // Refresh Token for OAuth auto-renew
  autoReplyEnabled   Boolean      @default(false)
  autoReplyMinRating Int          @default(4) // Only auto-reply to reviews >= 4 stars
  autoReplyTemplate  String?      // Dynamic template string (e.g., "Hi {author}, thanks for your {rating}-star review!")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model GoogleReview {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  gmbReviewId    String       @unique // Google's unique review name/ID
  authorName     String
  authorPhoto    String?
  rating         Int
  comment        String?
  replyText      String?      // Our posted reply text
  repliedAt      DateTime?
  status         String       @default("UNREPLIED") // UNREPLIED, REPLIED, AUTO_REPLIED
  reviewCreatedAt DateTime    @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model GooglePost {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  gmbPostId      String?      @unique // Google's unique post ID once published
  postType       String       @default("STANDARD") // STANDARD, EVENT, OFFER
  summary        String       // Post content text
  mediaUrl       String?      // Optional image or video URL
  actionType     String?      // CALL_TO_ACTION: BOOK, ORDER, SHOP, LEARN_MORE, SIGN_UP, CALL
  actionUrl      String?
  eventTitle     String?      // For EVENT posts
  startDate      DateTime?    // For EVENT/OFFER posts
  endDate        DateTime?    // For EVENT/OFFER posts
  offerCode      String?      // For OFFER posts
  termsConditions String?     // For OFFER posts
  status         String       @default("PUBLISHED") // DRAFT, SCHEDULED, PUBLISHED, FAILED
  scheduledAt    DateTime?    // Null if published immediately
  publishedAt    DateTime?
  errorMessage   String?
  retryCount     Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model GoogleQuestion {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  gmbQuestionId  String       @unique
  authorName     String
  text           String
  aiAnswer       String?
  answerText     String?
  status         String       @default("UNANSWERED") // UNANSWERED, ANSWERED, AUTO_ANSWERED
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ─── Google Ads Account (one per connected customer ID per org) ──────────────
model GoogleAdAccount {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  customerId     String       // Google Ads customer ID (numeric, no dashes)
  name           String?      // Account descriptive name
  currencyCode   String?      // e.g. INR, USD
  timeZone       String?
  isManager      Boolean      @default(false)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, customerId])
}

model GoogleAdCampaign {
  id                  String            @id @default(uuid())
  organizationId      String
  organization        Organization      @relation(fields: [organizationId], references: [id])
  customerId          String            // which Google Ads account this belongs to
  googleAdsCampaignId String?           @unique
  name                String
  campaignType        String            @default("SEARCH") // SEARCH, DISPLAY, VIDEO, SMART, PERFORMANCE_MAX
  biddingStrategy     String?           // MANUAL_CPC, TARGET_CPA, TARGET_ROAS, MAXIMIZE_CLICKS, etc.
  targetCpa           Float?
  targetRoas          Float?
  budget              Float
  budgetResourceName  String?
  startDate           DateTime
  endDate             DateTime?
  status              String            @default("PAUSED") // ENABLED, PAUSED, REMOVED
  headlines           Json              @default("[]")
  descriptions        Json              @default("[]")
  keywords            Json              @default("[]")
  finalUrl            String?
  geoTargets          Json              @default("[]") // list of geo target IDs
  adSchedule         Json              @default("[]")
  networkSearch       Boolean           @default(true)
  networkDisplay      Boolean           @default(false)
  adGroups            GoogleAdGroup[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model GoogleAdGroup {
  id                    String          @id @default(uuid())
  organizationId        String
  campaignId            String
  campaign              GoogleAdCampaign @relation(fields: [campaignId], references: [id])
  customerId            String
  googleAdGroupId       String?
  googleCampaignId      String?         // the Google-side campaign ID
  name                  String
  status                String          @default("ENABLED") // ENABLED, PAUSED, REMOVED
  adGroupType           String          @default("SEARCH_STANDARD")
  cpcBidMicros          BigInt?         // CPC bid in micros
  targetCpaMicros       BigInt?
  ads                   GoogleAd[]
  keywords              GoogleAdKeyword[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([googleAdGroupId])
}

model GoogleAd {
  id                 String         @id @default(uuid())
  organizationId     String
  adGroupId          String
  adGroup            GoogleAdGroup  @relation(fields: [adGroupId], references: [id])
  customerId         String
  googleAdId         String?
  googleAdGroupId    String?
  adType             String         @default("RESPONSIVE_SEARCH_AD") // RESPONSIVE_SEARCH_AD, EXPANDED_TEXT_AD, RESPONSIVE_DISPLAY_AD
  status             String         @default("ENABLED")
  headlines          Json           @default("[]")
  descriptions       Json           @default("[]")
  finalUrls          Json           @default("[]")
  displayUrl         String?
  path1              String?
  path2              String?
  strengthLabel      String?        // POOR, AVERAGE, GOOD, EXCELLENT
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model GoogleAdKeyword {
  id                 String          @id @default(uuid())
  organizationId     String
  adGroupId          String
  adGroup            GoogleAdGroup   @relation(fields: [adGroupId], references: [id])
  customerId         String
  googleKeywordId    String?
  googleAdGroupId    String?
  text               String
  matchType          String          @default("BROAD") // BROAD, PHRASE, EXACT
  isNegative         Boolean         @default(false)
  status             String          @default("ENABLED")
  cpcBidMicros       BigInt?
  qualityScore       Int?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model GoogleAdExtension {
  id                 String          @id @default(uuid())
  organizationId     String
  customerId         String
  googleResourceName String?
  extensionType      String          // SITELINK, CALLOUT, CALL, LOCATION, IMAGE, PRICE, PROMOTION
  status             String          @default("ENABLED")
  data               Json            // flexible blob for all extension type fields
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model GoogleAdConversion {
  id                    String         @id @default(uuid())
  organizationId        String
  customerId            String
  googleResourceName    String?
  googleConversionId    String?
  name                  String
  category              String         @default("PURCHASE") // PURCHASE, SIGNUP, LEAD, PAGE_VIEW, etc.
  valuePerConversion    Float?
  countingType          String         @default("ONE_PER_CLICK") // ONE_PER_CLICK, MANY_PER_CLICK
  conversionWindow      Int            @default(30) // days
  status                String         @default("ENABLED")
  tag                   String?        // tracking tag snippet
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model LinkedInConfig {
  id                    String           @id @default(uuid())
  organizationId        String           @unique
  organization          Organization     @relation(fields: [organizationId], references: [id])
  accessToken           String?
  refreshToken          String?
  expiresIn             Int?
  tokenExpiry           DateTime?
  companyId             String?
  companyName           String?
  memberId              String?
  memberName            String?
  memberEmail           String?
  memberPicture         String?
  headline              String?
  vanityName            String?
  companyLogo           String?
  website               String?
  industry              String?
  description           String?
  webhookVerifyToken    String           @default(uuid())
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  profile               LinkedInProfile?
}

model LinkedInProfile {
  id             String         @id @default(uuid())
  organizationId String         @unique
  configId       String         @unique
  config         LinkedInConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  memberId       String
  name           String
  email          String?
  headline       String?
  picture        String?
  locale         String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model LinkedInSyncLog {
  id             String       @id @default(uuid())
  organizationId String
  event          String
  status         String
  details        String?
  timestamp      DateTime     @default(now())
}

model LinkedInPersonalPost {
  id             String       @id @default(uuid())
  organizationId String
  linkedinPostId String       @unique
  author         String
  summary        String
  mediaUrl       String?
  publishedAt    DateTime     @default(now())
  likesCount     Int          @default(0)
  commentsCount  Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model LinkedInPost {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  linkedinPostId String       @unique
  author         String
  summary        String
  mediaUrl       String?
  visibility     String       @default("PUBLIC")
  lifecycleState String       @default("PUBLISHED")
  publishedAt    DateTime     @default(now())
  likesCount     Int          @default(0)
  commentsCount  Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model GmailConfig {
  id                String       @id @default(uuid())
  organizationId    String       @unique
  organization      Organization @relation(fields: [organizationId], references: [id])
  emailAddress      String?
  accessToken       String?
  refreshToken      String?
  autoReplyEnabled  Boolean      @default(false)
  autoReplyTemplate String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model GmailThread {
  id             String         @id @default(uuid())
  threadId       String         @unique // Gmail API thread ID
  organizationId String
  subject        String?
  sender         String
  snippet        String?
  status         String         @default("UNREPLIED") // UNREPLIED, REPLIED, SKIPPED
  label          String         @default("INBOX")
  isStarred      Boolean        @default(false)
  isSpam         Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  messages       GmailMessage[]
}

model GmailMessage {
  id             String            @id @default(uuid())
  threadId       String
  thread         GmailThread       @relation(fields: [threadId], references: [threadId], onDelete: Cascade)
  messageId      String            @unique // Gmail API message ID
  direction      String            // "inbound" or "outbound"
  content        String            // Body of email
  htmlContent    String?           // Rich HTML body if present
  sender         String
  aiDraft        String?           // Cached AI reply if awaiting review/action
  createdAt      DateTime          @default(now())
  attachments    GmailAttachment[]
}

model GmailAttachment {
  id             String       @id @default(uuid())
  messageId      String
  message        GmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  attachmentId   String       // Gmail API attachment ID
  filename       String
  mimeType       String
  size           Int
  createdAt      DateTime     @default(now())
}

model GmailAutoReplyRule {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  keyword        String       // word or phrase to match (case-insensitive)
  replyText      String       // Reply message to send automatically
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("gmail_auto_reply_rules")
}
